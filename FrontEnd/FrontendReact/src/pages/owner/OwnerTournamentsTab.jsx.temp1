import React, { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import ReactDOM from 'react-dom';
import stadiumOwnerService from '../../services/stadiumOwnerService';
import { FiPlus, FiCalendar, FiUsers, FiSettings, FiX, FiUploadCloud, FiCheckCircle } from 'react-icons/fi';
import Swal from 'sweetalert2';
import { FaTrophy } from 'react-icons/fa';

export default function OwnerTournamentsTab() {
  const [tournaments, setTournaments] = useState([]);
  const [myStadiums, setMyStadiums] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');
  
  const [showCreateModal, setShowCreateModal] = useState(false);
  const [step, setStep] = useState(1);
  const [isUploading, setIsUploading] = useState(false);
  const [isSubmitting, setIsSubmitting] = useState(false);

  const [formData, setFormData] = useState({
    name: '',
    sportId: 1,
    stadium: '',
    format: 'League',
    scope: 'Internal', // Internal (N?i b?), Public (M? r?ng)
    entryFee: 0,
    maxTeams: 8,
    assignmentType: 'Manual', // Manual, Random
    maxPlayersPerTeam: 5,
    startDate: '',
    endDate: '',
    phone: '',
    idCardFrontUrl: '',
    idCardBackUrl: '',
    bankQrCodeUrl: '',
    agreeTerms: false,
  });
  const navigate = useNavigate();

  useEffect(() => {
    fetchData();
  }, []);

  const fetchData = async () => {
    try {
      setLoading(true);
      const [tournRes, stadiumRes] = await Promise.all([
        stadiumOwnerService.getTournaments().catch(() => ({ data: [] })),
        stadiumOwnerService.getMyStadiums().catch(() => ({ data: [] }))
      ]);
      setTournaments(tournRes.data || []);
      setMyStadiums(stadiumRes.data || []);
      if (stadiumRes.data && stadiumRes.data.length > 0) {
          setFormData(prev => ({ ...prev, stadium: stadiumRes.data[0].stadiumName }));
      }
    } catch (err) {
      setError('L·ªói khi t·∫£i danh s√°ch gi·∫£i ƒë·∫•u');
    } finally {
      setLoading(false);
    }
  };

  const handleFileUpload = async (e, field) => {
    const file = e.target.files[0];
    if (!file) return;
    try {
      setIsUploading(true);
      const form = new FormData();
      form.append('file', file);
      const res = await stadiumOwnerService.uploadMedia(form);
      const url = res.url || res;
      setFormData(prev => ({ ...prev, [field]: url }));
    } catch (err) {
      Swal.fire('L?i', 'KhÙng th? upload ?nh, vui lÚng th? l?i.', 'error');
    } finally {
      setIsUploading(false);
    }
  };

  const selectPackage = (teams, fee) => {
    setFormData(prev => ({ ...prev, maxTeams: teams, entryFee: fee }));
    setStep(2);
  };

  const handleCreateSubmit = async (e) => {
    e.preventDefault();
    
    if (step === 2) {
      if (formData.scope === 'Internal') {
        // Skip KYC for Internal tournaments
        await submitTournament();
        return;
      }
      setStep(3);
      return;
    }

    if (step === 3) {
      if (!formData.agreeTerms) {
        Swal.fire('Ch˙ ˝', 'Vui lÚng d?ng ˝ v?i c·c di?u kho?n.', 'warning');
        return;
      }
      if (!formData.phone || !formData.idCardFrontUrl || !formData.idCardBackUrl) {
        Swal.fire('Ch˙ ˝', 'Vui lÚng cung c?p d?y d? thÙng tin KYC (S–T, m?t tru?c, m?t sau CCCD).', 'warning');
        return;
      }
      await submitTournament();
    }
  };

  const submitTournament = async () => {
    setIsSubmitting(true);
