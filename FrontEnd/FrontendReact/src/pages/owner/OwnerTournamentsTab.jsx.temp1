                        <option value="Knockout">Lo·∫°i tr·ª±c ti·∫øp (Single Elimination)</option>
                        <option value="DoubleElimination">Nh√°nh Th·∫Øng/Thua (Double Elimination)</option>
                        <option value="GroupStage">V√≤ng b·∫£ng (Group Stage)</option>
